# ============================================================
# AI股票分析系统环境配置模板
# ============================================================
# 使用说明：
# 1. 复制此文件并重命名为 .env
# 2. 根据实际情况填写配置项
# 3. 敏感信息（如API密钥、密码）请妥善保管，不要提交到版本控制
# ============================================================

# ========== 网络代理 ==========
# 全项目统一代理入口，改一处即生效。留空则直连。
PROXY_URL=http://your_proxy_host:port

# ========== Redis 缓存 ==========
# 可选。用于知识库结果缓存、分布式锁等
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_DB=0
# 或使用单行 URL: REDIS_URL=redis://your_host:6379/0

# ========== 嵌入与重排 ==========
# BGE-M3 嵌入服务（向量检索用）
BGE_URL=http://your_embed_server:11434/v1/embeddings
# TEI Reranker 重排服务（精排召回结果）
TEI_RERANK_URL=http://your_rerank_server:8080

# ========== 通知渠道 ==========
# QQ 机器人 Webhook（与 QQ bot endpoint 对接）
QQ_WEBHOOK_URL=http://127.0.0.1:18888/webhook/qq
# NOTIFICATION_ROUTE_ALERT=qq
# NOTIFICATION_ROUTE_REPORT=email,dingtalk

# ========== LLM API 配置 ==========
# 方舟（Ark）API 密钥 / 兼容 OpenAI SDK 的 API 密钥
# 获取地址：https://console.volcengine.com/ark
DEEPSEEK_API_KEY=your_api_key_here

# 方舟（Ark）API 地址 / 兼容 OpenAI SDK 的 base_url
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ========== 妙想(东方财富 AI SaaS)外部服务配置 ==========
# 可选。MCP 工具 mx_*(个股诊断/热点/可比/资讯搜索/宏观/研报)用,定位"第二意见/外部数据"。
EM_API_KEY=your_em_key_here

# AI模型名称（可选，支持OpenAI兼容的任意模型）
# 常用模型：deepseek-v4-pro, qwen-plus, gpt-4o 等
DEFAULT_MODEL_NAME=deepseek-v4-pro

# 深度分析/选股专用模型（默认跟随 DEFAULT_MODEL_NAME）
# DEEPSEEK_MODEL=deepseek-v4-pro
# 思维链模型（可选，用于复杂推理，留空则不启用 thinking）
# DEEPSEEK_THINKING_MODEL=


# ========== LLM 降级 provider（全部可选 / 全部按 OpenAI 兼容 SDK 接入）==========
# 规则:每个 provider 必须同时配置 <NAME>_API_KEY 和 <NAME>_BASE_URL 才会进入降级链;
#       否则该 provider 直接跳过, 不会出现"打了降级日志但没下家"的情况。
# 顺序:默认按下面 1→6 优先级降级;可用 LLM_PROVIDER_ORDER 改顺序(逗号分隔)。
# 第三方中转 / 自建反代 直接改 <NAME>_BASE_URL 即可, 无需改代码。
#
# LLM_PROVIDER_ORDER=deepseek,siliconflow,tongyi
# LLM_TIMEOUT=40            # 单 provider 调用超时(秒), thinking 模型至少 120

# 1. 硅基流动(国内聚合, 含 DeepSeek/Qwen 等)
# SILICONFLOW_API_KEY=
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
# SILICONFLOW_THINKING_MODEL=deepseek-ai/DeepSeek-R1

# 2. 阿里通义千问(TONGYI_* 与 DASHSCOPE_* 同义)
# TONGYI_API_KEY=
# TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# TONGYI_MODEL=qwen-plus
# TONGYI_THINKING_MODEL=qwq-plus

# 3. Google Gemini(OpenAI 兼容端点)
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_THINKING_MODEL=gemini-2.5-pro

# 4. OpenRouter 聚合
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=deepseek/deepseek-chat
# OPENROUTER_THINKING_MODEL=anthropic/claude-3.7-sonnet:thinking

# 5. Anthropic Claude(CLAUDE_* 与 ANTHROPIC_* 同义)
# CLAUDE_API_KEY=
# CLAUDE_BASE_URL=https://api.anthropic.com/v1
# CLAUDE_MODEL=claude-3-5-sonnet-latest
# CLAUDE_THINKING_MODEL=claude-3-7-sonnet-latest

# 6. 本地 Ollama(无需 API key, 只看 BASE_URL 探活;留空 → 不激活)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_THINKING_MODEL=deepseek-r1:14b


# ========== PostgreSQL 数据后端（可选）==========
# 启用后，分析记录 / 持仓数据 / 龙虎榜数据将存储到 PostgreSQL，否则使用 SQLite
# 切换前请确保 PG 数据库已创建对应表结构（参考 database_pg.py / portfolio_db_pg.py）
USE_POSTGRES=false
PG_HOST=127.0.0.1
PG_PORT=55432
PG_DATABASE=aiagents_stock
PG_USER=aiagents_stock
PG_PASSWORD=


# ========== Tushare数据接口（可选）==========
# Tushare Token（可选，用于获取更多金融数据）
# 获取地址：https://tushare.pro/register
TUSHARE_TOKEN=


# ========== MiniQMT量化交易配置（可选）==========
# 是否启用MiniQMT量化交易接口
MINIQMT_ENABLED=false

# MiniQMT账户ID
MINIQMT_ACCOUNT_ID=

# MiniQMT服务器地址
MINIQMT_HOST=127.0.0.1

# MiniQMT服务器端口
MINIQMT_PORT=58610

# ========== 下单风控门(fail-closed,AI盯盘自动下单前校验)==========
# 留空用默认。任一硬约束不满足则拒单。
# RISK_GATE_EXCLUDE=          # 排除名单,逗号分隔代码,如 600519,000001
# RISK_GATE_ALLOW_ST=false    # 是否允许买 ST/退市风险股
# RISK_GATE_SINGLE_MAX_PCT=25 # 买入后单票占总资产上限%
# RISK_GATE_TOTAL_MAX_PCT=95  # 买入后总仓位上限%
# RISK_GATE_MAX_DAILY_ORDERS=20  # 日内下单次数上限
# RISK_GATE_MAX_SINGLE_ORDER=0   # 单笔金额上限(元,0=不限)
# RISK_GATE_LIMIT_PCT=9.7     # 追涨停阈值(主板,当日涨幅≥此拒买)
# RISK_GATE_LIMIT_PCT_STAR=19.7  # 创业板/科创板涨停阈值


# ========== 邮件通知配置（可选）==========
# 是否启用邮件通知
EMAIL_ENABLED=false

# SMTP服务器地址
# 常用邮箱SMTP服务器：
#   - 163邮箱：smtp.163.com
#   - QQ邮箱：smtp.qq.com
#   - Gmail：smtp.gmail.com
#   - 企业邮箱：根据邮箱服务商提供的信息填写
SMTP_SERVER=smtp.163.com

# SMTP服务器端口
# 常用端口：
#   - 465：SSL加密连接163邮箱常用（推荐）
#   - 587：TLS加密连接
SMTP_PORT=465

# 发件人邮箱地址
EMAIL_FROM=your_email@163.com

# 邮箱授权码（不是登录密码！）
# 获取方法：
#   - 163邮箱：设置 -> POP3/SMTP/IMAP -> 开启服务 -> 获取授权码
#   - QQ邮箱：设置 -> 账户 -> POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务 -> 开启服务 -> 生成授权码
EMAIL_PASSWORD=your_email_authorization_code

# 收件人邮箱地址（接收通知的邮箱）
EMAIL_TO=receiver@example.com


# ========== Webhook通知配置（可选）==========
# 是否启用Webhook通知（钉钉/飞书）
WEBHOOK_ENABLED=false

# Webhook类型
# 可选值：dingtalk（钉钉）、feishu（飞书）
WEBHOOK_TYPE=dingtalk

# Webhook地址
# 钉钉机器人：https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN
# 飞书机器人：https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID
WEBHOOK_URL=

# Webhook自定义关键词（仅钉钉需要）
# 说明：
#   - 如果钉钉机器人设置了"自定义关键词"安全验证，请在此填写关键词
#   - 系统会自动在消息标题和内容中包含此关键词
#   - 如果不使用关键词验证，可以留空或使用其他安全方式（加签、IP白名单）
#   - 飞书机器人通常不需要关键词，可以留空
# 示例：aiagents通知
WEBHOOK_KEYWORD=


# ========== 多渠道推送路由（可选）— 由 notification_router.py 使用 ==========
# 企业微信群机器人 Webhook
WECHAT_WORK_WEBHOOK=

# Telegram Bot（在 BotFather 申请）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord 频道 Webhook
DISCORD_WEBHOOK_URL=

# Slack Incoming Webhook
SLACK_WEBHOOK_URL=

# 路由配置（可选）— 留空则按类型发送到所有可用渠道
# 用逗号分隔渠道名（email/dingtalk/feishu/wechat_work/telegram/discord/slack）
# NOTIFICATION_ROUTE_ALERT=dingtalk,telegram
# NOTIFICATION_ROUTE_REPORT=email,wechat_work
# NOTIFICATION_ROUTE_SYSTEM_ERROR=telegram
# NOTIFICATION_ROUTE_DAILY_SUMMARY=email,wechat_work


# ========== 时区配置 ==========
# 系统时区设置（可选）
TZ=Asia/Shanghai


# ========== TDX数据源API配置（策略监控必须）==========
# TDX API服务地址
# 说明：
#   - 用于获取股票K线数据和技术指标
#   - 默认本地服务地址：http://127.0.0.1:5000
#   - 如果使用远程服务，请修改为实际地址
# API接口：
#   - /api/kline?code=000001&type=day  # 获取日K线数据
#   - /api/quote?code=000001           # 获取实时行情
#   - /api/health                      # 健康检查
TDX_BASE_URL=http://127.0.0.1:8181


# ========== 低价擒牛策略监控配置 ==========
# 扫描间隔（秒）
# 说明：
#   - 监控服务扫描股票的时间间隔
#   - 建议范围：30-300秒
#   - 默认值：60秒（每分钟扫描1次）
LOW_PRICE_BULL_SCAN_INTERVAL=60

# 持股天数限制
# 说明：
#   - 持股达到该天数后自动提醒卖出
#   - 按自然日计算，不区分交易日
#   - 默认值：5天
LOW_PRICE_BULL_HOLDING_DAYS=5


# ========== 项目启动时自动拉起后台服务/调度（autostart.py）==========
# 总开关
AUTOSTART_ENABLED=true

# 价格监测（含交易时段自动启停调度）— 推荐开
AUTOSTART_MONITOR=true

# Jobs Hub（盘前 08:30 预热 / 09:10 策略扫描 / 15:30 持仓快照 / 15:35 大盘 / 16:00 龙虎榜归档 / 周一 03:00 清理）— 推荐开
AUTOSTART_JOBS_HUB=true

# 低价擒牛策略监测（持仓>0 时自动判断卖出信号）— 持仓存在时建议开
AUTOSTART_LOW_PRICE_BULL=false

# 新闻流量调度（30min 同步热点 / 60min 预警 / 120min 深度分析 — 后者耗 AI token）
AUTOSTART_NEWS_FLOW=false

# 智策板块每日 AI 分析（消耗 AI token，按需开启）
AUTOSTART_SECTOR_STRATEGY=false
SECTOR_STRATEGY_TIME=09:00

# 持仓定时分析（消耗 AI token，按需开启）
AUTOSTART_PORTFOLIO=false
